# User backend service environment variables (example)

# Service
USER_BACKEND_PORT=4455
NODE_ENV=production

# Database (replace with your own)
USER_DATABASE_URL="postgresql://username:password@localhost:5432/scpper_user?schema=public"

# Mail agent base URL
MAIL_AGENT_BASE_URL="http://127.0.0.1:3110"

# Verification settings
USER_VERIFICATION_CODE_LENGTH=6
USER_VERIFICATION_TTL_MINUTES=10
USER_VERIFICATION_MAX_ATTEMPTS=5
USER_REGISTER_RATE_WINDOW_SECONDS=60

# Session secret (REQUIRED in production)
USER_SESSION_SECRET="changeme-generate-a-secure-random-key"

# CORS allowed origins (comma-separated, leave empty to allow all in development)
CORS_ALLOWED_ORIGINS="https://scpper.mer.run"

# Internal API key for user-backend's own /internal routes (backend WikidotBindingVerifyJob sends this)
INTERNAL_API_KEY="changeme-generate-a-secure-random-key"

# API key for calling mail-agent /send endpoint (must match mail-agent's MAIL_AGENT_API_KEY)
MAIL_AGENT_API_KEY="changeme-generate-a-secure-random-key"

# API key for calling BFF /internal routes (must match BFF's BFF_INTERNAL_API_KEY)
BFF_INTERNAL_API_KEY="changeme-generate-a-secure-random-key"
