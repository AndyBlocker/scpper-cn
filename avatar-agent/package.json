{
  "name": "avatar-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../scripts/service-runner.mjs avatar-agent build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node ../scripts/service-runner.mjs avatar-agent start",
    "dev": "node ../scripts/service-runner.mjs avatar-agent dev",
    "predev": "npm run build",
    "lint": "node ../scripts/service-bin-runner.mjs avatar-agent eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "prune": "node ../scripts/service-runner.mjs avatar-agent prune",
    "stat": "AVATAR_ROOT=/home/andyblocker/scpper-cn/.data/avatar-agent/avatars node dist/scripts/stat.js",
    "stat:pretty": "AVATAR_ROOT=/home/andyblocker/scpper-cn/.data/avatar-agent/avatars node dist/scripts/stat.js --pretty",
    "preimage:stat": "npm run build",
    "preimage:stat:pretty": "npm run build",
    "image:stat": "node --env-file=.env dist/scripts/image-stat.js",
    "image:stat:pretty": "node --env-file=.env dist/scripts/image-stat.js --pretty",
    "preimage:variants": "npm run build",
    "image:variants": "node --env-file=.env dist/scripts/image-variants.js"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "fs-extra": "^11.2.0",
    "image-size": "^1.2.1",
    "mime-types": "^2.1.35",
    "pg": "^8.16.3",
    "sharp": "^0.33.4",
    "pino": "^9.3.2",
    "undici": "^6.19.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.15.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.10"
  }
}
