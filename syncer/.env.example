# syncer 自有数据库（VoteSentinelCache / VoteChangeEvent）
SYNCER_DATABASE_URL="postgresql://user:pass@localhost:5434/scpper-syncer"

# 主库（只读，引导 PageVersion 数据）
DATABASE_URL="postgresql://user:pass@localhost:5434/scpper-cn"

# 代理（mihomo 负载均衡端口）
SYNCER_HTTP_PROXY="http://127.0.0.1:7891"

# Wikidot 站点
SYNCER_SITE_NAME="scp-wiki-cn"

# 哨兵循环间隔（秒）
SYNCER_INTERVAL_SECONDS=300

# Tier 2 并发
SYNCER_TIER2_CONCURRENCY=3
