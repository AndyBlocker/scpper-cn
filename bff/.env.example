# BFF service environment variables (example)

# Service
PORT=4396
NODE_ENV=production

# Database (replace with your own)
DATABASE_URL="postgresql://username:password@localhost:5432/scpper-cn"

# Redis (optional)
REDIS_URL="redis://:password@127.0.0.1:6379"

# Upstream user-backend base URL
USER_BACKEND_BASE_URL="http://127.0.0.1:4455"

# Caching
ENABLE_CACHE=true

# CORS allowed origins (comma-separated, leave empty to allow all in development)
CORS_ALLOWED_ORIGINS="https://scpper.mer.run"

# Internal API key for service-to-service auth (required — /internal routes reject without it)
BFF_INTERNAL_API_KEY="changeme-generate-a-secure-random-key"

